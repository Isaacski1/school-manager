# Example .env file (backend + frontend)
# Copy backend variables to server/.env and frontend variables to .env.local

PORT=3001

# Your Firebase Project ID
FIREBASE_PROJECT_ID=school-manager-gh

# Service Account Key JSON (from Firebase Console)
# Go to: Firebase Console → ⚙️ Settings → Service Accounts → Generate New Private Key
# Then paste the entire JSON content here (on a single line)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_CODE=
PAYSTACK_CALLBACK_URL=

# Book Demo notifications
DEMO_NOTIFY_EMAIL=info@schoolmanagergh.com
DEMO_NOTIFY_WHATSAPP=+233201008784
TRIAL_NOTIFY_EMAIL=info@schoolmanagergh.com
TRIAL_NOTIFY_WHATSAPP=+233549175604

# Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=School Manager GH

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Backend request limits
REQUEST_BODY_LIMIT=1mb
APP_VERSION=1.0.0
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://schoolmanagergh.com,https://www.schoolmanagergh.com
WHATSAPP_AUTO_INIT=true
JOBS_SHARED_SECRET=change-me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_MODEL=llama3
LLM_API_KEY=

# Google AI Studio
GOOGLE_API_KEY=
# Copy the active free-tier limits shown for this project in Google AI Studio.
# Leave a value empty when Google does not publish that limit for the model.
GOOGLE_AI_FREE_RPM_LIMIT=
GOOGLE_AI_FREE_TPM_LIMIT=
GOOGLE_AI_FREE_RPD_LIMIT=

# SMS gateway (backend)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=SchoolMgr

# Frontend (Vite)
VITE_PAYSTACK_PUBLIC_KEY=
VITE_API_BASE_URL=https://school-manager-hehk.onrender.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=school-manager-gh
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FUNCTIONS_REGION=
VITE_FIREBASE_APP_CHECK_SITE_KEY=
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
VITE_GA_MEASUREMENT_ID=G-G0RTW77NM6
