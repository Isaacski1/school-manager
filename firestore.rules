rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

     match /plans/{planId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.userRole == 'super_admin' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole == 'super_admin'
          )
        )
      );
    }

    function isSchoolAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school_admin';
    }

    function isTeacher() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function userSchoolId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId;
    }

    function isActiveUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active' ||
        !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['status']);
    }

    function isActiveSchoolId(schoolId) {
      return schoolId != null &&
        exists(/databases/$(database)/documents/schools/$(schoolId)) &&
        (
          get(/databases/$(database)/documents/schools/$(schoolId)).data.status == 'active' ||
          !get(/databases/$(database)/documents/schools/$(schoolId)).data.keys().hasAny(['status'])
        );
    }

    function maxStudentsForSchool(schoolId) {
      let school = get(/databases/$(database)/documents/schools/$(schoolId)).data;
      return school.keys().hasAny(['limits']) &&
        school.limits is map &&
        school.limits.keys().hasAny(['maxStudents']) &&
        (school.limits.maxStudents is int || school.limits.maxStudents is float)
        ? school.limits.maxStudents
        : null;
    }

    function studentsCountForSchool(schoolId) {
      let school = get(/databases/$(database)/documents/schools/$(schoolId)).data;
      return school.keys().hasAny(['studentsCount']) &&
        (school.studentsCount is int || school.studentsCount is float)
        ? school.studentsCount
        : 0;
    }

    // This rule allows super admins to perform collection group queries on 'payments'.
    // It is required for the super admin payments dashboard.
    match /{path=**}/payments/{paymentId} {
      allow read: if isSuperAdmin();
    }

    // Plans collection - Super admin only
    match /plans/{planId} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Users collection - STRICT security
    match /users/{userId} {
      // Super admin can create/delete any user and change role/schoolId
      allow create, delete: if isSuperAdmin();
      allow read, update: if isSuperAdmin();

      // School admin can delete teacher profiles in their own active school.
      allow delete: if isAuthenticated() && isActiveUser() &&
        isSchoolAdmin() &&
        userSchoolId() == resource.data.schoolId &&
        isActiveSchoolId(resource.data.schoolId) &&
        (
          resource.data.role == 'teacher' ||
          resource.data.userRole == 'teacher'
        );

      // School admin can read users in their school, update users in their school but cannot change role/schoolId
      allow read: if isSchoolAdmin() && userSchoolId() == resource.data.schoolId;
      allow update: if isSchoolAdmin() &&
                       userSchoolId() == resource.data.schoolId &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.schoolId == resource.data.schoolId;

      // Authenticated users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Users can update only safe fields on their own profile (cannot change role/schoolId)
      allow update: if isAuthenticated() &&
                       request.auth.uid == userId &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.schoolId == resource.data.schoolId;

      // Teachers can read their own profile (redundant but explicit)
      allow read: if isTeacher() && request.auth.uid == userId;
    }

    // Schools collection
    match /schools/{schoolId} {
      // Super admin can read/write all schools
      allow read, write: if isSuperAdmin();

      // School admin can read their own school
      allow read: if isSchoolAdmin() && userSchoolId() == schoolId;

      // Teachers can read their own school (needed for dashboard/profile loading)
      allow read: if isTeacher() && userSchoolId() == schoolId;

      // No write for school admins on schools
      allow write: if false;
    }

    // Finance v2 subcollections (scoped by school)
    match /schools/{schoolId}/fees/{feeId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "feeName",
          "amount",
          "classId",
          "academicYear",
          "term",
          "createdAt",
          "updatedAt",
          "createdBy",
          "feeFrequency",
          "appliesTo",
          "effectiveFromDate",
          "dueDate",
          "selectedStudentIds",
          "applyToAcademicYear",
          "applyToTerm"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "feeName",
          "amount",
          "classId",
          "academicYear",
          "term",
          "createdAt",
          "updatedAt",
          "createdBy",
          "feeFrequency",
          "appliesTo",
          "effectiveFromDate",
          "dueDate",
          "selectedStudentIds",
          "applyToAcademicYear",
          "applyToTerm"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId);
    }

    match /schools/{schoolId}/feeLedgers/{ledgerId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "academicYear",
          "term",
          "fees",
          "createdAt",
          "updatedAt",
          "openingPaidAmount",
          "openingBalance",
          "openingStatus",
          "openingDate"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "academicYear",
          "term",
          "fees",
          "createdAt",
          "updatedAt",
          "openingPaidAmount",
          "openingBalance",
          "openingStatus",
          "openingDate"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId);
    }

    match /schools/{schoolId}/payments/{paymentId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "feeId",
          "feeName",
          "amountPaid",
          "paymentMethod",
          "receiptNumber",
          "academicYear",
          "term",
          "createdAt",
          "recordedBy",
          "amount",
          "currency",
          "reference",
          "status",
          "event",
          "adminEmail",
          "schoolName",
          "isOpeningPayment"
        ]);

      allow get: if schoolScopedRead(schoolId);

      allow list: if isSuperAdmin() ||
        (isAuthenticated() && isSchoolAdmin() && userSchoolId() == schoolId);

      allow read: if schoolScopedRead(schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "feeId",
          "feeName",
          "amountPaid",
          "paymentMethod",
          "receiptNumber",
          "academicYear",
          "term",
          "createdAt",
          "recordedBy",
          "amount",
          "currency",
          "reference",
          "status",
          "event",
          "adminEmail",
          "schoolName",
          "isOpeningPayment"
        ]);

      allow delete: if isSuperAdmin();
    }

    match /schools/{schoolId}/financeSettings/{docId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == schoolId &&
        onlyAllowedFields([
          "schoolId",
          "financeVersion",
          "onboardingMode",
          "onboardingDate",
          "createdAt",
          "updatedAt"
        ]);

      allow read: if schoolScopedRead(schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "schoolId",
          "financeVersion",
          "onboardingMode",
          "onboardingDate",
          "createdAt",
          "updatedAt"
        ]);

      allow delete: if isSuperAdmin();
    }

    // Settings collection (per school config)
    match /settings/{document} {
      // Super admin can read/write all settings
      allow read, write: if isSuperAdmin();

      // School admin can read/write their school's settings
      allow read, write: if isSchoolAdmin() && userSchoolId() == document;
    }

    // Field whitelisting helpers
    function onlyAllowedFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function schoolScopedCreate(schoolId) {
      return isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
         ((isSchoolAdmin() || isTeacher()) && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId);
    }

    function schoolScopedRead(schoolId) {
      return isAuthenticated() && isActiveUser() &&
        (
          isSuperAdmin() ||
          (((isSchoolAdmin() || isTeacher()) && userSchoolId() == schoolId) &&
            isActiveSchoolId(schoolId))
        );
    }

    function schoolScopedDelete(schoolId) {
      return isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
         (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId);
    }

    function schoolAdminScopedAccess(schoolId) {
      return isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
         (isSchoolAdmin() && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId);
    }

    function schoolScopedUpdate(schoolId) {
      return isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
         ((isSchoolAdmin() || isTeacher()) && userSchoolId() == schoolId)) &&
        isActiveSchoolId(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;
    }

    // Students collection
    match /students/{studentId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        (maxStudentsForSchool(request.resource.data.schoolId) == null ||
         maxStudentsForSchool(request.resource.data.schoolId) <= 0 ||
         studentsCountForSchool(request.resource.data.schoolId) <
           maxStudentsForSchool(request.resource.data.schoolId)) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "name",
          "gender",
          "dob",
          "classId",
          "guardianName",
          "guardianPhone",
          "studentStatus",
          "createdAt"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "name",
          "gender",
          "dob",
          "classId",
          "guardianName",
          "guardianPhone",
          "studentStatus",
          "createdAt"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "date",
          "classId",
          "presentStudentIds",
          "isHoliday",
          "holidayReason"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "date",
          "classId",
          "presentStudentIds",
          "isHoliday",
          "holidayReason"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Assessments collection
    match /assessments/{assessmentId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "subject",
          "testScore",
          "homeworkScore",
          "projectScore",
          "examScore",
          "total"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "subject",
          "testScore",
          "homeworkScore",
          "projectScore",
          "examScore",
          "total"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Teacher attendance collection
    match /teacher_attendance/{recordId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "date",
          "teacherId",
          "status",
          "approvalStatus",
          "approvedBy",
          "approvedAt",
          "rejectedBy",
          "rejectedAt",
          "isHoliday",
          "holidayReason"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "date",
          "teacherId",
          "status",
          "approvalStatus",
          "approvedBy",
          "approvedAt",
          "rejectedBy",
          "rejectedAt",
          "isHoliday",
          "holidayReason"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Notices collection
    match /notices/{noticeId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "message",
          "date",
          "type",
          "createdAt"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "message",
          "date",
          "type",
          "createdAt"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Student remarks collection
    match /student_remarks/{remarkId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "remark",
          "behaviorTag",
          "teacherId",
          "dateCreated"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "remark",
          "behaviorTag",
          "teacherId",
          "dateCreated"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Student skills collection
    match /student_skills/{skillId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "punctuality",
          "neatness",
          "conduct",
          "attitudeToWork",
          "classParticipation",
          "homeworkCompletion"
        ]);

      allow read: if schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "punctuality",
          "neatness",
          "conduct",
          "attitudeToWork",
          "classParticipation",
          "homeworkCompletion"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Admin remarks collection
    match /admin_remarks/{remarkId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == request.resource.data.schoolId)) &&
        isActiveSchoolId(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "remark",
          "adminId",
          "dateCreated"
        ]);

      // Allow fetching a remark doc ID even when it doesn't exist yet.
      allow get: if isAuthenticated() && isActiveUser() &&
        (
          isSuperAdmin() ||
          (
            isSchoolAdmin() &&
            (
              !exists(/databases/$(database)/documents/admin_remarks/$(remarkId)) ||
              (
                userSchoolId() ==
                  get(/databases/$(database)/documents/admin_remarks/$(remarkId)).data.schoolId &&
                isActiveSchoolId(
                  get(/databases/$(database)/documents/admin_remarks/$(remarkId)).data.schoolId
                )
              )
            )
          )
        );

      allow read: if isAuthenticated() && (isSuperAdmin() || isActiveUser()) &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "term",
          "academicYear",
          "remark",
          "adminId",
          "dateCreated"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId);
    }

    // System notifications collection
    match /admin_notifications/{notificationId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == request.resource.data.schoolId)) &&
        isActiveSchoolId(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "message",
          "createdAt",
          "isRead",
          "type"
        ]);

      allow read: if isSuperAdmin() ||
        (isAuthenticated() && isActiveUser() &&
          isSchoolAdmin() &&
          userSchoolId() == resource.data.schoolId &&
          isActiveSchoolId(resource.data.schoolId));

      // Allow super‑admins to enumerate all notifications. School admins
      // should only see notifications that belong to their school, which is
      // expressed by validating the incoming query.  Without this rule a
      // query such as `where('schoolId','==', '<id>')` will be rejected with
      // a permissions error even though the documents themselves would be
      // readable via the `get` rule above.  The client code always includes
      // that filter via `db.getSystemNotifications(schoolId)`.

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "message",
          "createdAt",
          "isRead",
          "type"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() ||
          (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId);
    }

    // Timetables collection
    match /timetables/{timetableId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "schoolId",
          "classId",
          "schedule",
          "updatedAt"
        ]);

      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "schoolId",
          "classId",
          "schedule",
          "updatedAt"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Fees collection
    match /fees/{feeId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == request.resource.data.schoolId)) &&
        isActiveSchoolId(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "feeName",
          "amount",
          "classId",
          "academicYear",
          "term",
          "createdAt",
          "updatedAt",
          "createdBy",
          "feeFrequency",
          "appliesTo",
          "effectiveFromDate",
          "dueDate",
          "selectedStudentIds",
          "applyToAcademicYear",
          "applyToTerm"
        ]);

      allow read: if schoolScopedRead(resource.data.schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "feeName",
          "amount",
          "classId",
          "academicYear",
          "term",
          "createdAt",
          "updatedAt",
          "createdBy",
          "feeFrequency",
          "appliesTo",
          "effectiveFromDate",
          "dueDate",
          "selectedStudentIds",
          "applyToAcademicYear",
          "applyToTerm"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId);
    }

    // Student fee ledgers collection
    match /student_ledgers/{ledgerId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == request.resource.data.schoolId)) &&
        isActiveSchoolId(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "academicYear",
          "term",
          "fees",
          "createdAt",
          "updatedAt",
          "openingPaidAmount",
          "openingBalance",
          "openingStatus",
          "openingDate"
        ]);

      allow read: if schoolScopedRead(resource.data.schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "academicYear",
          "term",
          "fees",
          "createdAt",
          "updatedAt",
          "openingPaidAmount",
          "openingBalance",
          "openingStatus",
          "openingDate"
        ]);

      allow delete: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId);
    }

    // Student fee payments collection
    match /payments/{paymentId} {
      allow create: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == request.resource.data.schoolId)) &&
        isActiveSchoolId(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "id",
          "schoolId",
          "studentId",
          "classId",
          "feeId",
          "feeName",
          "amountPaid",
          "paymentMethod",
          "receiptNumber",
          "academicYear",
          "term",
          "createdAt",
          "recordedBy",
          "amount",
          "currency",
          "reference",
          "status",
          "event",
          "adminEmail",
          "schoolName",
          "isOpeningPayment"
        ]);

      // Resource-scoped read handles both document reads and queries.
      allow read: if isSuperAdmin() || schoolScopedRead(resource.data.schoolId);

      allow update: if isAuthenticated() && isActiveUser() &&
        (isSuperAdmin() || (isSchoolAdmin() && userSchoolId() == resource.data.schoolId)) &&
        isActiveSchoolId(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isSuperAdmin();
    }

    // Class subjects collection
    match /class_subjects/{subjectId} {
      allow create: if schoolScopedCreate(request.resource.data.schoolId) &&
        onlyAllowedFields([
          "schoolId",
          "classId",
          "subjects"
        ]);

      allow read: if schoolScopedRead(resource.data.schoolId);

      allow update: if schoolScopedUpdate(resource.data.schoolId) &&
        onlyAllowedFields([
          "schoolId",
          "classId",
          "subjects"
        ]);

      allow delete: if schoolScopedDelete(resource.data.schoolId);
    }

    // Analytics events (super admin + school scoped)
    match /analyticsEvents/{eventId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() &&
        (isSuperAdmin() || schoolScopedRead(resource.data.schoolId));
      allow update, delete: if isSuperAdmin();
    }

    // Backups collection
    match /backups/{backupId} {
      // Resource-scoped read handles both document reads and queries.
      allow read: if isSuperAdmin() || schoolAdminScopedAccess(resource.data.schoolId);
      allow create: if schoolAdminScopedAccess(request.resource.data.schoolId);
      allow update, delete: if isSuperAdmin() ||
        schoolAdminScopedAccess(resource.data.schoolId);
    }

    // Activity logs for analytics and auditing
    match /activity_logs/{logId} {
      // Creation of logs: allowed if authenticated and either super_admin or creating for your own school
      allow create: if isAuthenticated() && (
        isSuperAdmin() || (userSchoolId() == request.resource.data.schoolId)
      );

      // Read: super_admin can read all. School admins/teachers can read logs for their school only.
      allow get: if isSuperAdmin() || (
        isAuthenticated() && userSchoolId() != null && userSchoolId() == resource.data.schoolId
      );

      // List (query) — only super_admin allowed to list all logs via queries
      allow list: if isSuperAdmin();

      // Updates/deletes: only super_admin
      allow update, delete: if isSuperAdmin();
    }

    // School-scoped activity logs
    match /schools/{schoolId}/activityLogs/{logId} {
      allow create: if isAuthenticated() &&
        (isSuperAdmin() || schoolScopedRead(schoolId));
      allow get: if isAuthenticated() &&
        (isSuperAdmin() || schoolScopedRead(schoolId));
      allow list: if isAuthenticated() &&
        (isSuperAdmin() || schoolScopedRead(schoolId));
      allow update, delete: if isSuperAdmin();
    }

    // Platform-wide broadcasts
    match /platformBroadcasts/{broadcastId} {
      allow create, update, delete: if isSuperAdmin();
      allow get: if isAuthenticated() && (
        isSuperAdmin() ||
        (
          request.auth != null &&
          (
            resource.data.targetType == 'ALL' ||
            (resource.data.targetType == 'SCHOOLS' &&
              resource.data.targetSchoolIds.hasAny([userSchoolId()]))
          )
        )
      );
      allow list: if isAuthenticated();
    }

    // Security login logs (super admin only)
    match /securityLoginLogs/{logId} {
      allow create: if isSuperAdmin();
      allow read, update, delete: if isSuperAdmin();
    }

    // Suspicious events (super admin only)
    match /suspiciousEvents/{eventId} {
      allow create, read, update, delete: if isSuperAdmin();
    }

    // Audit logs (super admin only)
    match /auditLogs/{logId} {
      allow create, read, update, delete: if isSuperAdmin();
    }

    // Platform security settings (super admin only)
    match /platformSecuritySettings/{docId} {
      allow create, read, update, delete: if isSuperAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

