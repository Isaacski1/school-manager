{
  "name": "school-manager-gh",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --test server/termRollover.test.js",
    "test:term-rollover": "node --test server/termRollover.test.js",
    "ai:eval": "node scripts/ai-eval.mjs",
    "env:test": "node scripts/switch-env.mjs test",
    "env:prod": "node scripts/switch-env.mjs prod",
    "start": "node server/server.js",
    "server:dev": "nodemon",
    "backfill:payout-ledger": "node scripts/backfillPayoutLedger.mjs",
    "backfill:payout-ledger:write": "node scripts/backfillPayoutLedger.mjs --write",
    "mfa:totp:dry-run": "node scripts/enableTotpMfa.mjs --dry-run",
    "mfa:totp:enable": "node scripts/enableTotpMfa.mjs",
    "mfa:user:clear:dry-run": "node scripts/clearUserMfaFactors.mjs --dry-run",
    "mfa:user:clear": "node scripts/clearUserMfaFactors.mjs",
    "predeploy": "npm run build",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run env:prod && npm run build && firebase deploy --project school-manager-gh --only hosting",
    "deploy:prod:firestore": "firebase deploy --project school-manager-gh --only firestore",
    "deploy:staging": "npm run env:test && npm run build && firebase deploy --project noble-care-management-system --only hosting",
    "deploy:staging:firestore": "firebase deploy --project noble-care-management-system --only firestore"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@types/jszip": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.7.0",
    "firebase-admin": "^12.0.0",
    "framer-motion": "^12.0.0",
    "html2pdf.js": "^0.12.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-paystack": "^6.0.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^2.12.7",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "gh-pages": "^6.3.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
